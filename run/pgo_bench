#!/usr/bin/env bash
# Benchmark the C++ PGO loop closure on the exported loop-closure datasets and
# print the trajectory-ATE / marker-spread / loop-recall table.
#
# Compares three loop-closure configs on each dataset, under injected odom drift:
#   stock  - the in-tree C++ SimplePGO (point-to-point PCL ICP, 10 m corr.)
#   gated  - bounded ICP correspondence + max-offset reject (false-loop guard)
#   ivan   - port of dimos pgo.py: point-to-plane ICP + decoupled rot/trans noise
#
# Reads the neutral files in data/loop_bench/<dataset>/ (clouds.bin, the clean
# FAST-LIO trajectory, AprilTag groundtruth). Those are produced once by
# loop_closure_bench/scripts/export_dataset.py from the dimos recordings (needs
# the dimos env); this script only benchmarks already-exported data, so it just
# needs cmake + brew PCL/Eigen + the locally-built GTSAM.
#
# Usage:
#   ./run/pgo_bench                       # build if needed, benchmark all datasets at yaw 0 + 1.0
#   ./run/pgo_bench --rebuild             # force-rebuild the C++ harness
#   ./run/pgo_bench --yaw 0.0 0.5 1.0     # custom drift levels
#   ./run/pgo_bench --datasets hk_village3 outdoor_small_loop
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BENCH="$ROOT/loop_closure_bench"
HARNESS="$BENCH/harness/build/pgo_bench"
RUST_HARNESS="$BENCH/rust/target/release/pgo_bench_rs"
DATA="$ROOT/data/loop_bench"
PY=(uv run --quiet --with numpy --with scipy python)

REBUILD=0
PASSTHRU=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --rebuild) REBUILD=1; shift ;;
    *) PASSTHRU+=("$1"); shift ;;
  esac
done

# 1. Build the C++ harness via nix (GTSAM + PCL + Eigen all from one nixpkgs).
if [[ $REBUILD -eq 1 || ! -x "$HARNESS" ]]; then
  echo ">> building C++ PGO benchmark harness (nix)..."
  bash "$BENCH/harness/build_harness.sh"
fi

# 1b. Build the Rust port (the `rust` config benchmarks Ivan's PGO in Rust).
if [[ $REBUILD -eq 1 || ! -x "$RUST_HARNESS" ]]; then
  echo ">> building Rust PGO harness (cargo)..."
  ( cd "$BENCH/rust" && cargo build --release )
fi

# 2. Default to the datasets that are actually exported (have clouds + groundtruth).
if [[ ! " ${PASSTHRU[*]:-} " =~ " --datasets " ]]; then
  found=()
  for d in "$DATA"/*/; do
    name="$(basename "$d")"
    [[ -f "$d/clouds.bin" && -f "$d/groundtruth.json" ]] && found+=("$name")
  done
  if [[ ${#found[@]} -eq 0 ]]; then
    echo "!! no exported datasets in $DATA — run loop_closure_bench/scripts/export_dataset.py first" >&2
    exit 1
  fi
  PASSTHRU+=(--datasets "${found[@]}")
fi
# Default drift levels if none requested.
[[ " ${PASSTHRU[*]} " =~ " --yaw " ]] || PASSTHRU+=(--yaw 0.0 1.0)

echo ">> benchmarking PGO loop closure (stock / gated / ivan)..."
(cd "$BENCH/scripts" && "${PY[@]}" run_all.py "${PASSTHRU[@]}")

TSV="$BENCH/scripts/results.tsv"
echo
echo "==================== results ($TSV) ===================="
column -t -s$'\t' "$TSV"
echo
echo "ate_drift = trajectory RMSE vs clean before PGO; ate_pgo = after PGO (lower is better)."
echo "See loop_closure_bench/CONCLUSIONS.md for interpretation."
