#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

BINARY="./rust/target/release/fastlio2-rerun"
CONFIG="fastlio2/config/lio.yaml"
BAG="${1:-data/ruwik2_pt3_bag_custom/ruwik2_pt3_bag_custom_0.mcap}"
OUTPUT="${2:-logs.ignore/fastlio2_output.rrd}"

if [ ! -f "$BINARY" ]; then
    echo "Binary not found. Building..."
    cd rust && cargo build --release --bin fastlio2-rerun && cd ..
fi

mkdir -p "$(dirname "$OUTPUT")"
"$BINARY" "$CONFIG" "$BAG" "$OUTPUT"
echo ""
echo "View with: rerun $OUTPUT"
